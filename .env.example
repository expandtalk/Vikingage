# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id-here"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# OpenRouter API key is set as a Supabase secret (server-side only):
#   supabase secrets set OPENROUTER_API_KEY=sk-or-...
# Do NOT add it here — it must never be exposed to the browser.

# Google Maps API (optional - for geolocation)
# Get your key from: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"
